# .env.example
# Copy to .env and fill in your API keys

# Default API key (used as fallback)
ANTHROPIC_API_KEY=your-default-api-key-here

# Mode-specific API keys (optional - will use default if not set)
ANTHROPIC_API_KEY_EXTENDED=your-extended-thinking-key
ANTHROPIC_API_KEY_ANALYSIS=your-analysis-key
ANTHROPIC_API_KEY_CREATIVE=your-creative-key
ANTHROPIC_API_KEY_CODING=your-coding-key

# Server configuration
PROXY_HOST=0.0.0.0
PROXY_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=proxy.log
LOG_REQUESTS=true
